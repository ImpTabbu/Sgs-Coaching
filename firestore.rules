rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    //   - email: string (required)
    //   - name: string (required)
    //   - role: string (required, 'student', 'teacher', 'admin')
    //   - active: boolean (required)
    //   - uid: string (required)
    // Collection: notifications, gallery, studyMaterials, toppers, tests, testQuestions, testResults, noticeBoard, prePrimaryContent, kahanis, appSettings, teachers, socialLinks, successStories
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "wanamotivation@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, maxLen) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= maxLen;
    }

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 100 &&
             data.name is string && data.name.size() <= 100 &&
             data.role in ['student', 'teacher', 'admin'] && 
             data.active is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      allow create: if isAuthenticated() && 
                    isValidUser(request.resource.data) && 
                    request.resource.data.uid == request.auth.uid &&
                    (request.resource.data.role == 'student' || isAdmin()) &&
                    (request.resource.data.active == false || isAdmin());
                    
      allow update: if isAuthenticated() && 
                    isValidUser(request.resource.data) && 
                    (
                      isAdmin() || 
                      (
                        isOwner(userId) && 
                        uidNotModified() &&
                        request.resource.data.role == resource.data.role &&
                        request.resource.data.active == resource.data.active
                      )
                    );
                    
      allow delete: if isAdmin();
    }

    // Generic rule for admin-only write collections with size limits
    function isAdminWriteValid(maxTitleLen, maxContentLen) {
      return isAdmin() && 
             (!('title' in request.resource.data) || isValidString('title', maxTitleLen)) &&
             (!('content' in request.resource.data) || isValidString('content', maxContentLen));
    }

    // Test Results collection
    match /testResults/{resultId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && 
                    request.resource.data.score is number;
      allow update, delete: if isAdmin();
    }

    // Public content collections
    match /notifications/{id} { allow read: if isAuthenticated(); allow write: if isAdminWriteValid(200, 2000); }
    match /gallery/{id} { allow read: if isAuthenticated(); allow write: if isAdminWriteValid(200, 1000); }
    match /studyMaterials/{id} { allow read: if isAuthenticated(); allow write: if isAdminWriteValid(200, 1000); }
    match /toppers/{id} { allow read: if isAuthenticated(); allow write: if isAdminWriteValid(200, 500); }
    match /tests/{id} { allow read: if isAuthenticated(); allow write: if isAdminWriteValid(200, 500); }
    match /testQuestions/{id} { allow read: if isAuthenticated(); allow write: if isAdminWriteValid(500, 2000); }
    match /noticeBoard/{id} { allow read: if isAuthenticated(); allow write: if isAdminWriteValid(200, 5000); }
    match /prePrimaryContent/{id} { allow read: if isAuthenticated(); allow write: if isAdminWriteValid(200, 1000); }
    match /kahanis/{id} { allow read: if isAuthenticated(); allow write: if isAdminWriteValid(200, 10000); }
    match /appSettings/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /teachers/{id} { allow read: if isAuthenticated(); allow write: if isAdminWriteValid(200, 1000); }
    match /socialLinks/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /successStories/{id} { allow read: if isAuthenticated(); allow write: if isAdminWriteValid(200, 2000); }
  }
}
